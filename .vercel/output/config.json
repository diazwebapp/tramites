{
	"version": 3,
	"routes": [
		{
			"handle": "filesystem"
		},
		{
			"src": "^/_astro/(.*)$",
			"headers": {
				"cache-control": "public, max-age=31536000, immutable"
			},
			"continue": true
		},
		{
			"src": "^/_server-islands/([^/]+?)/?$",
			"dest": "_render"
		},
		{
			"src": "^/_image/?$",
			"dest": "_render"
		},
		{
			"src": "^/api/admin/?$",
			"dest": "_render"
		},
		{
			"src": "^/api/personas/?$",
			"dest": "_render"
		},
		{
			"src": "^/api/rcv/?$",
			"dest": "_render"
		},
		{
			"src": "^/api/vehiculos/?$",
			"dest": "_render"
		},
		{
			"src": "^/create-person/?$",
			"dest": "_render"
		},
		{
			"src": "^/create-vehicle/?$",
			"dest": "_render"
		},
		{
			"src": "^/info/?$",
			"dest": "_render"
		},
		{
			"src": "^/$",
			"dest": "_render"
		}
	]
}