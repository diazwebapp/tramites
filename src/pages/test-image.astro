---
// src/pages/index.astro o similar
---

<div class="p-8 max-w-2xl mx-auto">
  <h1 class="text-2xl font-bold mb-4">Extractor de Títulos de Vehículos</h1>
  
  <input type="file" id="imageInput" accept="image/*" class="mb-4 block w-full" />
  <button id="uploadBtn" class="bg-blue-600 text-white px-4 py-2 rounded">Procesar Imagen</button>

  <form id="resultForm" class="hidden mt-8 space-y-4 border-t pt-4">
    <div class="grid grid-cols-2 gap-4">
      <label>Placa: <input type="text" name="placa" class="border p-2 w-full" /></label>
      <label>Marca: <input type="text" name="marca" class="border p-2 w-full" /></label>
      <label>Modelo: <input type="text" name="modelo" class="border p-2 w-full" /></label>
      <label>RIF: <input type="text" name="rif" class="border p-2 w-full" /></label>
    </div>
    <button type="submit" class="bg-green-600 text-white px-4 py-2 rounded">Enviar al Backend Final</button>
  </form>
</div>

<script>
  const btn = document.getElementById('uploadBtn');
  const input = document.getElementById('imageInput') as HTMLInputElement;
  const form = document.getElementById('resultForm') as HTMLFormElement;

  btn?.addEventListener('click', async () => {
    if (!input.files?.[0]) return alert("Selecciona una imagen");

    const formData = new FormData();
    formData.append("documento", input.files[0]);

    btn.innerText = "Procesando...";
    
    const res = await fetch('/api/extract.json', { method: 'POST', body: formData });
    const data = await res.json();

    // Llenar el formulario con los datos de la IA
    if (data) {
      form.classList.remove('hidden');
      Object.keys(data).forEach(key => {
        const field = form.querySelector(`[name="${key}"]`) as HTMLInputElement;
        if (field) field.value = data[key];
      });
    }
    btn.innerText = "Procesar Imagen";
  });
</script>